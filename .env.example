# See README.md (Authentication, Production checklist) and AGENTS.md for full context.
#
# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public URL of this app (no trailing slash). MUST match the URL in the browser (OAuth redirect).
BETTER_AUTH_URL=http://localhost:3000
# Same as BETTER_AUTH_URL for production; required at build time for the browser client when not using localhost.
# NEXT_PUBLIC_BETTER_AUTH_URL=https://your-app.example.com
# Optional: extra allowed origins (comma-separated), e.g. https://www.example.com,https://example.com
# BETTER_AUTH_TRUSTED_ORIGINS=

# Keycloak OIDC — issuer must include realm, e.g. https://keycloak.kshrd.app/realms/my-realm
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ISSUER=https://keycloak.kshrd.app/realms/YOUR_REALM

# In Keycloak, set Valid redirect URIs to:
#   {BETTER_AUTH_URL}/api/auth/oauth2/callback/keycloak
# Web origins: your app origin (e.g. http://localhost:3000)
